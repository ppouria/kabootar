# SQLite DB used for bridge settings/state
DATABASE_URL=sqlite:///./data/app.db

# DNS bridge primary domain (authoritative zone)
DNS_DOMAIN=t.example.com
# Optional additional domains (comma separated). DNS_DOMAIN is always included.
DNS_DOMAINS=

# DNS bind/listen
DNS_BIND_ADDRESS=0.0.0.0
DNS_PORT=5533
DNS_TTL=30

# Access mode:
# free  -> clients can push channel routes (upmeta/uppart/upcommit)
# fixed -> server ignores client pushes and serves only TELEGRAM_CHANNELS
DNS_ACCESS_MODE=free

# Optional password for DNS bridge auth (client gets session token via auth.<client>.<sha1(password)>.<domain>)
DNS_PASSWORD=
DNS_SESSION_TTL_SECONDS=3600

# How often the bridge refreshes from Telegram (seconds)
DNS_REFRESH_SECONDS=60

# Number of latest Telegram messages read per channel
DNS_RECENT_PER_CHANNEL=50

# Fixed/default channels fetched by server (comma separated usernames/urls).
# In fixed mode these are mandatory channels served to all clients.
TELEGRAM_CHANNELS=

# Optional proxies for Telegram fetches
# socks5://ip:port
# socks5://user:pass@ip:port
# http://ip:port
TELEGRAM_PROXIES=

# Fallback recursive resolver for non-bridge DNS names
DNS_FALLBACK_HOST=127.0.0.1
DNS_FALLBACK_PORT=5300

# Bundle sizing hints (bytes)
DNS_TEXT_BUNDLE_TARGET_BYTES=5000
DNS_MEDIA_BUNDLE_TARGET_BYTES=48000

# Max image size to embed in DNS payload (bytes)
DNS_MEDIA_MAX_BYTES=180000
DNS_AVATAR_MAX_BYTES=60000

# Optional custom Persian encoder lexicon path (advanced)
KABOOTAR_PERSIAN_ENCODER_DB=
# Legacy alias for the same path
PERSIAN_ENCODER_DB_PATH=
